# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — Reddit search is skipped if these are not set
# Get credentials at: https://www.reddit.com/prefs/apps
# Create an app of type "script", note the client ID (under app name) and secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=StartupResearch/1.0 by YourRedditUsername
